# Pearls AQI Predictor — Environment Configuration
# Copy this file to .env and fill in your actual keys:
#   cp .env.example .env

# ── Hopsworks (get from https://app.hopsworks.ai → Account → API Keys) ──
HOPWORKS_API_KEY=
HOPWORKS_PROJECT_NAME=Pearls_AQI

# ── AQICN (get from https://aqicn.org/data-api/token/) ──
AQICN_API_TOKEN=

# ── OpenWeather (get from https://home.openweathermap.org/api_keys) ──
OPENWEATHER_API_KEY=

# ── Tracked Cities (JSON array) ──
CITIES=["Delhi","Mumbai","Bangalore","Chennai","Kolkata"]
